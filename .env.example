# Copy to .env or .env.test.local (see docs/TEST_ENVIRONMENT.md)
# Get URL + anon key from Supabase → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key
# Some hosts still use the older name; client.ts accepts either:
# VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Must match a row in public.tenants.slug (default for localhost / reserved hosts)
# VITE_DEFAULT_TENANT_SLUG=lakecity

# Optional: show pre-maintenance ribbon + full-page gate during the UTC window in src/components/MaintenanceGate.tsx
# VITE_SCHEDULED_MAINTENANCE=true

# --- Optional: local scripts (e.g. npm run sheet:rename-collection-schedule-tab) ---
# Same values as Supabase Edge Function secrets where applicable.
# SPREADSHEET_ID is the segment from:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
# SPREADSHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}  # full JSON, one line or escaped newlines
